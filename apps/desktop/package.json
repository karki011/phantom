{
  "name": "@phantom-os/desktop",
  "productName": "PhantomOS",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PhantomOS Electron Desktop App",
  "author": "Subash Karki",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "prebuild:dist": "node scripts/copy-native-modules.cjs",
    "compile:app": "electron-vite build",
    "package": "electron-builder --mac",
    "dist:mac": "npm run prebuild:dist && electron-builder --mac && node scripts/validate-native-runtime.cjs",
    "dist:dir": "npm run prebuild:dist && electron-builder --dir && node scripts/validate-native-runtime.cjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@mantine/core": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@mantine/notifications": "^9.0.1",
    "@phantom-os/db": "workspace:*",
    "@phantom-os/editor": "workspace:*",
    "@phantom-os/gamification": "workspace:*",
    "@phantom-os/panes": "workspace:*",
    "@phantom-os/server": "workspace:*",
    "@phantom-os/shared": "workspace:*",
    "@phantom-os/terminal": "workspace:*",
    "@phantom-os/theme": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "bindings": "^1.5.0",
    "file-uri-to-path": "^1.0.0",
    "jotai": "^2.19.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-toastify": "^11.0.5",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0"
  }
}