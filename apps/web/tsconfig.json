{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@phantom/theme": ["./src/theme/phantom-theme"],
      "@phantom/atoms/*": ["./src/atoms/*"],
      "@phantom/hooks/*": ["./src/hooks/*"],
      "@phantom/lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src"]
}
