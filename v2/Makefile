.PHONY: dev build clean test lint sqlc frontend-install frontend-build frontend-typecheck go-build go-test go-lint ci mcp-build mcp-bundle docs-llm release release-build release-sign release-notarize release-zip release-dmg onnx-setup

# --- Release config ---
# Auto-load Apple notarization credentials from parent dir (sibling of v2/).
# File is gitignored. See ../.env.notarize.example for the schema.
-include ../.env.notarize
export APPLE_ID APPLE_APP_SPECIFIC_PASSWORD APPLE_TEAM_ID

APP_NAME      := Phantom
APP_BUNDLE    := build/bin/$(APP_NAME).app
APP_MACOS     := $(APP_BUNDLE)/Contents/MacOS
SIGN_IDENTITY := Developer ID Application: Subash Karki (Z825V2BBX9)
TEAM_ID       := Z825V2BBX9
ENTITLEMENTS  := build/darwin/entitlements.plist
DIST_DIR      := build/dist
VERSION       := $(shell cat VERSION 2>/dev/null || echo dev)

# Development (CGO_LDFLAGS points the linker at the ONNX runtime in ~/.phantom-os/lib)
dev: mcp-build
	CGO_LDFLAGS="-L$(HOME)/.phantom-os/lib" wails dev -tags onnx

# Developer convenience: download ONNX runtime + model to ~/.phantom-os/
onnx-setup:
	@go run ./cmd/onnx-setup

# Production build — also bundles the phantom-mcp child binary into the .app.
build: mcp-build
	wails build -clean
	$(MAKE) mcp-bundle

# Frontend
frontend-install:
	cd frontend && pnpm install

frontend-build:
	cd frontend && pnpm build

frontend-typecheck:
	cd frontend && pnpm typecheck

# Docs digest for LLM agents — concatenate curated docs into a single file at repo root.
# Order matters: header + TOC first, then README, ai-engine, design, plans.
docs-llm:
	@echo "==> generating llms-full.txt"
	@{ \
		echo "# Phantom — agent context"; \
		echo ""; \
		echo "Generated by \`make docs-llm\`. Single-file digest of curated docs for LLM agents."; \
		echo "Source of truth lives in the linked files; regenerate this file after doc changes."; \
		echo ""; \
		echo "## Table of contents"; \
		echo ""; \
		echo "1. README.md"; \
		echo "2. docs/ai-engine.md"; \
		echo "3. docs/DESIGN-config-driven-architecture.md"; \
		echo "4. docs/PLAN-home-redesign.md"; \
		echo "5. docs/PLAN-phase-1-upgrades.md"; \
		echo ""; \
		echo "---"; \
		echo ""; \
		if [ -f README.md ]; then \
			echo "## === README.md ==="; \
			echo ""; \
			cat README.md; \
			echo ""; \
		fi; \
		echo "## === docs/ai-engine.md ==="; \
		echo ""; \
		cat docs/ai-engine.md; \
		echo ""; \
		echo "## === docs/DESIGN-config-driven-architecture.md ==="; \
		echo ""; \
		cat docs/DESIGN-config-driven-architecture.md; \
		echo ""; \
		echo "## === docs/PLAN-home-redesign.md ==="; \
		echo ""; \
		cat docs/PLAN-home-redesign.md; \
		echo ""; \
		echo "## === docs/PLAN-phase-1-upgrades.md ==="; \
		echo ""; \
		cat docs/PLAN-phase-1-upgrades.md; \
	} > llms-full.txt
	@SIZE=$$(wc -c < llms-full.txt); \
		echo "✓ llms-full.txt ($$SIZE bytes)"; \
		if [ $$SIZE -gt 204800 ]; then \
			echo "WARN: llms-full.txt exceeds 200 KB ($$SIZE bytes)"; \
		fi

# Go
go-build:
	go build -o build/bin/phantomos .

# Standalone MCP stdio binary spawned by Claude Code.
mcp-build:
	go build -o build/bin/phantom-mcp ./cmd/phantom-mcp

# Universal MCP binary used for release builds (matches darwin/universal target).
mcp-build-universal:
	GOOS=darwin GOARCH=arm64 go build -trimpath -ldflags "-s -w" -o build/bin/phantom-mcp-arm64 ./cmd/phantom-mcp
	GOOS=darwin GOARCH=amd64 go build -trimpath -ldflags "-s -w" -o build/bin/phantom-mcp-amd64 ./cmd/phantom-mcp
	lipo -create -output build/bin/phantom-mcp build/bin/phantom-mcp-arm64 build/bin/phantom-mcp-amd64
	rm -f build/bin/phantom-mcp-arm64 build/bin/phantom-mcp-amd64

# Copy the compiled phantom-mcp binary next to the main app executable inside
# the .app bundle so MCP registration can resolve it via os.Executable() at
# runtime. Idempotent — overwrites any previous copy.
mcp-bundle:
	@test -f build/bin/phantom-mcp || (echo "missing build/bin/phantom-mcp — run 'make mcp-build' first"; exit 1)
	@test -d "$(APP_MACOS)" || (echo "missing $(APP_MACOS) — run 'make build' first"; exit 1)
	cp build/bin/phantom-mcp "$(APP_MACOS)/phantom-mcp"
	chmod +x "$(APP_MACOS)/phantom-mcp"
	@echo "✓ phantom-mcp bundled at $(APP_MACOS)/phantom-mcp"

go-test:
	go test ./... -v -race

go-lint:
	golangci-lint run ./...

# sqlc (Phase 1+)
sqlc:
	sqlc generate

# Clean
clean:
	rm -rf build/bin
	rm -rf build/frontend
	rm -rf frontend/node_modules

# All tests
test: go-test frontend-typecheck

# CI
ci: frontend-install frontend-build go-build

# --- Release flow (local) ---
# Credentials are auto-loaded from ../.env.notarize (gitignored sibling file):
#   APPLE_ID                     -- Apple ID email
#   APPLE_APP_SPECIFIC_PASSWORD  -- app-specific password from appleid.apple.com
#   APPLE_TEAM_ID                -- 10-char team ID (overrides $(TEAM_ID) if set)
#
# Pipelines:
#   make release-zip  -- universal build + sign + notarize + staple + .zip
#   make release-dmg  -- everything in release-zip + a polished .dmg (needs `brew install create-dmg`)
#   make release      -- alias for release-dmg

release: release-dmg

release-build: mcp-build-universal
	@echo "==> wails build (universal, trimmed)"
	wails build -clean -trimpath -platform darwin/universal -ldflags "-s -w"
	@echo "==> bundling phantom-mcp into .app"
	$(MAKE) mcp-bundle

release-sign: release-build
	@echo "==> codesign with hardened runtime"
	@test -f "$(ENTITLEMENTS)" || (echo "missing $(ENTITLEMENTS)"; exit 1)
	codesign --deep --force --options=runtime --timestamp \
		--entitlements "$(ENTITLEMENTS)" \
		--sign "$(SIGN_IDENTITY)" \
		"$(APP_BUNDLE)"
	codesign --verify --strict --verbose=2 "$(APP_BUNDLE)"

release-notarize: release-sign
	@echo "==> notarize via notarytool"
	@test -n "$$APPLE_ID" || (echo "APPLE_ID not set (check ../.env.notarize)"; exit 1)
	@test -n "$$APPLE_APP_SPECIFIC_PASSWORD" || (echo "APPLE_APP_SPECIFIC_PASSWORD not set (check ../.env.notarize)"; exit 1)
	mkdir -p $(DIST_DIR)
	ditto -c -k --keepParent "$(APP_BUNDLE)" "$(DIST_DIR)/$(APP_NAME)-notarize.zip"
	xcrun notarytool submit "$(DIST_DIR)/$(APP_NAME)-notarize.zip" \
		--apple-id "$$APPLE_ID" \
		--team-id "$${APPLE_TEAM_ID:-$(TEAM_ID)}" \
		--password "$$APPLE_APP_SPECIFIC_PASSWORD" \
		--wait
	xcrun stapler staple "$(APP_BUNDLE)"
	xcrun stapler validate "$(APP_BUNDLE)"
	rm -f "$(DIST_DIR)/$(APP_NAME)-notarize.zip"

release-zip: release-notarize
	@echo "==> packaging $(APP_NAME)-$(VERSION).zip"
	mkdir -p $(DIST_DIR)
	ditto -c -k --keepParent "$(APP_BUNDLE)" "$(DIST_DIR)/$(APP_NAME)-$(VERSION).zip"
	@echo "✓ $(DIST_DIR)/$(APP_NAME)-$(VERSION).zip"

release-dmg: release-notarize
	@echo "==> packaging $(APP_NAME)-$(VERSION).dmg"
	@command -v create-dmg >/dev/null || (echo "create-dmg not installed: brew install create-dmg"; exit 1)
	mkdir -p $(DIST_DIR)
	rm -f "$(DIST_DIR)/$(APP_NAME)-$(VERSION).dmg"
	create-dmg \
		--volname "$(APP_NAME)" \
		--window-size 540 380 \
		--icon-size 96 \
		--icon "$(APP_NAME).app" 140 190 \
		--app-drop-link 400 190 \
		"$(DIST_DIR)/$(APP_NAME)-$(VERSION).dmg" \
		"$(APP_BUNDLE)"
	@echo "✓ $(DIST_DIR)/$(APP_NAME)-$(VERSION).dmg"
