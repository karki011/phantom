# Copy to .env.notarize and fill in. .env.notarize is gitignored.
#
# Where to get each value:
#   APPLE_ID                     — the email address on your Apple Developer account.
#   APPLE_APP_SPECIFIC_PASSWORD  — https://appleid.apple.com → Sign-In and Security
#                                  → App-Specific Passwords → Generate (name it
#                                  "phantomos-notarize"). Format: xxxx-xxxx-xxxx-xxxx.
#   APPLE_TEAM_ID                — https://developer.apple.com/account → Membership.
#                                  10-character Team ID, e.g. ABCD123456.
#
# You also need a "Developer ID Application" certificate in your login Keychain.
# Install via Xcode → Settings → Accounts → Manage Certificates → + → Developer ID Application.

APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=ABCD123456
