{
  "name": "phantom-os",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "description": "PhantomOS — Solo Leveling System gamified Claude session dashboard",
  "author": "Subash Karki",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:api": "turbo dev:api --filter=@phantom-os/server",
    "dev:all": "turbo dev",
    "dev:desktop": "turbo dev --filter=@phantom-os/desktop",
    "test": "vitest",
    "test:run": "vitest run",
    "test:stress": "vitest run --reporter=verbose --pool=forks packages/server/src/__stress__/",
    "test:stress:all": "bun run test:stress:api; bun run test:stress:chat; bun run test:stress:db; bun run test:stress:realtime; bun run test:stress:projects; bun run test:stress:resources",
    "test:stress:api": "vitest run --reporter=verbose packages/server/src/__stress__/api-routes.stress.test.ts",
    "test:stress:chat": "vitest run --reporter=verbose packages/server/src/__stress__/chat.stress.test.ts",
    "test:stress:db": "vitest run --reporter=verbose packages/server/src/__stress__/database.stress.test.ts",
    "test:stress:realtime": "vitest run --reporter=verbose packages/server/src/__stress__/realtime.stress.test.ts",
    "test:stress:projects": "vitest run --reporter=verbose packages/server/src/__stress__/projects-worktrees.stress.test.ts",
    "test:stress:resources": "vitest run --reporter=verbose packages/server/src/__stress__/resource-limits.stress.test.ts",
    "dist:mac": "rm -rf apps/desktop/release && turbo build && cd apps/desktop && bun run dist:mac",
    "postinstall": "chmod +x node_modules/.bun/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true; bash scripts/patch-electron-name.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^12.0.0",
    "driver.js": "^1.4.0",
    "jotai": "^2.19.1",
    "jotai-tanstack-query": "^0.11.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.9.4",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "bufferutil",
    "electron",
    "esbuild",
    "node-pty",
    "utf-8-validate"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
